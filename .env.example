# Copy this file to config/.env and fill in your values.

API_ID=
API_HASH=
DEFAULT_PHONE=
# Optional: if empty, Telethon will use a file session in data/sessions/
STRING_SESSION=

SESSION_NAME=telegram_manager
SESSION_DIR=data/sessions
DATABASE_PATH=data/telegram_manager.db
LOG_DIR=logs
TIMEZONE=Europe/Vilnius
LOG_LEVEL=INFO

MAX_RETRIES=5
REQUEST_RETRIES=3
CONNECTION_RETRIES=3
RETRY_DELAY_SECONDS=2
MAX_BATCH_SIZE=100
MAX_SCHEDULED_PER_CHAT=100
DIALOG_FETCH_LIMIT=200
SESSION_CHECK_TIMEOUT_SECONDS=25