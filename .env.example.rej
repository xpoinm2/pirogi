diff a/.env.example b/.env.example	(rejected hunks)
@@ -1,22 +1,24 @@
 # Copy this file to config/.env and fill in your values.
+# API_ID/API_HASH are required by Telethon internally, but are hidden from GUI workflow.
 
 API_ID=
 API_HASH=
-DEFAULT_PHONE=
-# Optional: if empty, Telethon will use a file session in data/sessions/
+
+# Optional fallback string session for CLI/automation.
 STRING_SESSION=
 
+# Optional fallback session filename when no imported .session is selected.
 SESSION_NAME=telegram_manager
 SESSION_DIR=data/sessions
 DATABASE_PATH=data/telegram_manager.db
 LOG_DIR=logs
 TIMEZONE=Europe/Vilnius
 LOG_LEVEL=INFO
 
 MAX_RETRIES=5
 REQUEST_RETRIES=3
 CONNECTION_RETRIES=3
 RETRY_DELAY_SECONDS=2
 MAX_BATCH_SIZE=100
 MAX_SCHEDULED_PER_CHAT=100
 DIALOG_FETCH_LIMIT=200
